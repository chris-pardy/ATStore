{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["config/oxlint/rules-base.json", "config/oxlint/overrides.json"],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true,
    "es2026": true
  },
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/src/lexicons/generated/bundle.ts",
    "eslint.config.js",
    "**/public/**/*.js",
    "**/node_modules",
    "**/.DS_Store",
    "**/dist",
    "**/dist-ssr",
    "**/*.local",
    "**/count.txt",
    "**/.env",
    "**/.nitro",
    "**/.tanstack",
    "**/.wrangler",
    "**/.output",
    "**/.vinxi",
    "**/todos.json",
    "**/mcp-todos.json",
    "**/.content-collections",
    "**/.vite",
    "**/.nx/**",
    "**/.svelte-kit/**",
    "**/build/**",
    "**/coverage/**",
    "**/dist/**",
    "**/snap/**",
    "**/vite.config.*.timestamp-*.*"
  ],
  "jsPlugins": [
    "@eslint-community/eslint-plugin-eslint-comments",
    "eslint-plugin-perfectionist"
  ],
  "settings": {
    "import-x/resolver": {
      "typescript": {
        "alwaysTryTypes": true
      }
    }
  }
}
